# Banco (usado pelo serviço postgres e pelo backend)
POSTGRES_USER=gestao
POSTGRES_PASSWORD=gestao123
POSTGRES_DB=gestao_escalas
POSTGRES_PORT=55432

# Backend
DATABASE_URL=postgresql://gestao:gestao123@postgres:5432/gestao_escalas?schema=public
APP_PORT=4000
BACKEND_PORT=54000
NODE_ENV=production
JWT_SECRET=change_me

# Frontend
FRONTEND_PORT=53000
# URL interna entre containers (Next server-side -> backend)
API_INTERNAL_URL=http://backend:4000
# Para testes com deploy simples no Coolify, mantenha igual à URL interna
NEXT_PUBLIC_API_URL=http://backend:4000
